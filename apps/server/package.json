{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.mjs",
		"auth:gen": "bun x @better-auth/cli generate --config ../.././packages/auth/src/index.ts --output ../.././packages/db/prisma/schema/auth.prisma"
	},
	"dependencies": {
		"@client-pulse/api": "workspace:*",
		"@client-pulse/auth": "workspace:*",
		"@client-pulse/db": "workspace:*",
		"@client-pulse/env": "workspace:*",
		"@hono/node-server": "^1.14.4",
		"@hono/trpc-server": "^0.4.0",
		"@trpc/server": "catalog:",
		"@types/nodemailer": "^7.0.11",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"nodemailer": "^8.0.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@client-pulse/config": "workspace:*",
		"@types/node": "^22.13.14",
		"tsdown": "^0.16.5",
		"tsx": "^4.19.2",
		"typescript": "^5"
	}
}
