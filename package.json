{
  "name": "client-pulse",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.2.0",
      "@trpc/client": "^11.7.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @client-pulse/db db:push",
    "db:studio": "turbo -F @client-pulse/db db:studio",
    "db:generate": "turbo -F @client-pulse/db db:generate",
    "db:migrate": "turbo -F @client-pulse/db db:migrate",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@client-pulse/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@client-pulse/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
